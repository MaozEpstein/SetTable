rules_version = '2';

// Production-ready security rules for SetTable.
//
// Layered protections:
//  1. Auth gates — only signed-in users; group data only to members
//  2. Ownership — usernames/profiles are owner-write-only
//  3. Shape & size — every writable field is type-checked and length-capped
//     to prevent DoS via storage bloat or malformed data
//  4. Rate hints — counters/timestamps where atomic enforcement is feasible
//
// Deploy: paste the entire file into Firebase Console → Firestore → Rules → Publish

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helper functions ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(groupData) {
      return isSignedIn() && request.auth.uid in groupData.memberUids;
    }

    function isAdmin(groupData) {
      return isSignedIn() && (
        request.auth.uid in (groupData.admins is list ? groupData.admins : []) ||
        (!('admins' in groupData) && groupData.createdBy == request.auth.uid)
      );
    }

    function isMemberOfGroup(groupId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    // String of bounded length. Use for required text fields.
    function isBoundedString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }

    // Optional bounded string: missing OR within bounds.
    function isOptionalBoundedString(data, field, maxLen) {
      return !(field in data) ||
        (data[field] is string && data[field].size() <= maxLen);
    }

    // List of strings within size limits.
    function isStringList(value, maxItems, maxItemLen) {
      return value is list && value.size() <= maxItems;
      // Note: per-item length cannot be cheaply asserted in Firestore
      // rules without an O(n) helper; we cap the array length and rely
      // on the client + Cloudinary preset to bound individual items.
    }

    // Timestamp must be a number, not too far in the future (24h grace
    // for clock skew). Prevents users from forging "ancient" or "year 3000"
    // entries to manipulate sort order or analytics.
    function isReasonableTimestamp(t) {
      return t is number &&
        t > 0 &&
        t < (request.time.toMillis() + 86400000);
    }

    // ---------- groups ----------
    match /groups/{groupId} {
      allow get: if isSignedIn() && isMember(resource.data);
      allow list: if isSignedIn();

      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.memberUids &&
        request.resource.data.createdBy == request.auth.uid &&
        isBoundedString(request.resource.data.name, 2, 50) &&
        isBoundedString(request.resource.data.code, 6, 6) &&
        request.resource.data.memberUids is list &&
        request.resource.data.memberUids.size() <= 100 &&
        // Lifetime cap of 80 groups created per user. Treats missing
        // userProfile or missing counter as 0 for backward-compat with
        // groups created before this rule existed.
        (
          !exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) ||
          !('groupsCreated' in get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data) ||
          get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.groupsCreated < 80
        );

      allow update: if isSignedIn() && (
        // (a) joining: only added yourself
        (
          !(request.auth.uid in resource.data.memberUids) &&
          request.auth.uid in request.resource.data.memberUids &&
          request.resource.data.memberUids.size() <= 100
        ) ||
        // (b)+(c)+(d) member ops
        (
          isMember(resource.data) &&
          // Even members can't blow up the group with garbage
          (!('name' in request.resource.data) ||
            isBoundedString(request.resource.data.name, 2, 50)) &&
          (!('memberUids' in request.resource.data) ||
            (request.resource.data.memberUids is list &&
             request.resource.data.memberUids.size() <= 100)) &&
          (!('manualMembers' in request.resource.data) ||
            (request.resource.data.manualMembers is list &&
             request.resource.data.manualMembers.size() <= 50)) &&
          (!('customSlots' in request.resource.data) ||
            (request.resource.data.customSlots is list &&
             request.resource.data.customSlots.size() <= 20)) &&
          (!('customCategories' in request.resource.data) ||
            (request.resource.data.customCategories is list &&
             request.resource.data.customCategories.size() <= 30))
        )
      );

      allow delete: if false;

      // ---------- foods ----------
      match /foods/{foodId} {
        allow read: if isMemberOfGroup(groupId);

        allow create: if isMemberOfGroup(groupId) &&
          isBoundedString(request.resource.data.name, 2, 100) &&
          isStringList(request.resource.data.categories, 10, 100) &&
          request.resource.data.createdBy == request.auth.uid &&
          isReasonableTimestamp(request.resource.data.createdAt) &&
          isOptionalBoundedString(request.resource.data, 'recipe', 5000) &&
          isOptionalBoundedString(request.resource.data, 'notes', 2000) &&
          (!('images' in request.resource.data) ||
            (request.resource.data.images is list &&
             request.resource.data.images.size() <= 20));

        allow update: if isMemberOfGroup(groupId) &&
          (!('name' in request.resource.data) ||
            isBoundedString(request.resource.data.name, 2, 100)) &&
          (!('categories' in request.resource.data) ||
            isStringList(request.resource.data.categories, 10, 100)) &&
          isOptionalBoundedString(request.resource.data, 'recipe', 5000) &&
          isOptionalBoundedString(request.resource.data, 'notes', 2000) &&
          (!('images' in request.resource.data) ||
            (request.resource.data.images is list &&
             request.resource.data.images.size() <= 20));

        allow delete: if isMemberOfGroup(groupId);
      }

      // ---------- foodNames (uniqueness markers) ----------
      match /foodNames/{normalizedName} {
        allow read, write: if isMemberOfGroup(groupId);
      }

      // ---------- assignments ----------
      match /assignments/{assignmentId} {
        allow read: if isMemberOfGroup(groupId);

        allow create: if isMemberOfGroup(groupId) &&
          isBoundedString(request.resource.data.slot, 1, 50) &&
          request.resource.data.createdBy == request.auth.uid &&
          isReasonableTimestamp(request.resource.data.createdAt) &&
          (request.resource.data.foodId == null ||
            isBoundedString(request.resource.data.foodId, 1, 100)) &&
          (!('done' in request.resource.data) ||
            request.resource.data.done is bool) &&
          isOptionalBoundedString(request.resource.data, 'note', 500);

        allow update: if isMemberOfGroup(groupId) &&
          (!('slot' in request.resource.data) ||
            isBoundedString(request.resource.data.slot, 1, 50)) &&
          (!('done' in request.resource.data) ||
            request.resource.data.done is bool) &&
          isOptionalBoundedString(request.resource.data, 'note', 500);

        allow delete: if isMemberOfGroup(groupId);
      }

      // ---------- history ----------
      match /history/{historyId} {
        allow read: if isMemberOfGroup(groupId);

        allow create: if isMemberOfGroup(groupId) &&
          request.resource.data.archivedBy == request.auth.uid &&
          isReasonableTimestamp(request.resource.data.archivedAt) &&
          request.resource.data.assignments is list &&
          request.resource.data.assignments.size() <= 500 &&
          request.resource.data.assignmentCount is number &&
          request.resource.data.assignmentCount <= 500 &&
          isOptionalBoundedString(request.resource.data, 'eventName', 200);

        allow update: if false; // history is immutable
        allow delete: if isMemberOfGroup(groupId);
      }

      // Catch-all for any other future subcollections — still member-only,
      // but no validators yet. Add explicit blocks above when you introduce
      // a new subcollection so the validators kick in.
      match /{document=**} {
        allow read, write: if isMemberOfGroup(groupId);
      }
    }

    // ---------- usernames ----------
    match /usernames/{username} {
      allow read: if true;

      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        username.matches('^[a-zA-Z0-9_]{3,20}$') &&
        isOptionalBoundedString(request.resource.data, 'email', 200);

      allow update: if isSignedIn() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.uid == request.auth.uid &&
        isOptionalBoundedString(request.resource.data, 'email', 200);

      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ---------- user profiles ----------
    match /userProfiles/{uid} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && request.auth.uid == uid &&
        isOptionalBoundedString(request.resource.data, 'displayName', 30) &&
        isOptionalBoundedString(request.resource.data, 'username', 20) &&
        isOptionalBoundedString(request.resource.data, 'email', 200);

      allow update: if isSignedIn() && request.auth.uid == uid &&
        isOptionalBoundedString(request.resource.data, 'displayName', 30) &&
        isOptionalBoundedString(request.resource.data, 'username', 20) &&
        isOptionalBoundedString(request.resource.data, 'email', 200) &&
        // Counter is monotonic — prevents bypass of the 80-group cap by
        // resetting groupsCreated to 0.
        (
          !('groupsCreated' in request.resource.data) ||
          (
            request.resource.data.groupsCreated is number &&
            request.resource.data.groupsCreated >=
              (resource.data.groupsCreated is number ? resource.data.groupsCreated : 0)
          )
        );

      allow delete: if isSignedIn() && request.auth.uid == uid;
    }

    // ---------- push tokens ----------
    match /pushTokens/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId &&
        isOptionalBoundedString(request.resource.data, 'token', 500);
    }

    // ---------- shared menu snapshots ----------
    match /sharedMenus/{shareId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        // Cap snapshot size to keep this collection from being weaponized
        // as free file hosting.
        request.resource.data.assignments is list &&
        request.resource.data.assignments.size() <= 500;
      allow update, delete: if false;
    }
  }
}
